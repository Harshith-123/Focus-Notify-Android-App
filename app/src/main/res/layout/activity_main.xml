<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F0F4FF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FocusNotify"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#1a73e8"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode: ADAPTIVE  |  FoMO: 25  |  ID: P00"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnSession"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="▶ START SESSION"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1a73e8"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚪ Session not active"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙ Settings"
            android:textSize="13sp"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnViewLog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 View Log"
            android:textSize="13sp"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnShareLog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📤 Share Log"
            android:textSize="13sp"
            android:backgroundTint="#43A047"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>
